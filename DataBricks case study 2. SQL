select
     UserID0,
     Channel2,
     RecordDate2,
     `Duration 2`,
     userid4,
     UserID,
     Email,
     Gender,
     Race,
     Age,
     Province,
     `Social Media Handle`,
     date_format(timestamp(RecordDate2), 'HH:mm:ss') AS SA_Normal_time,
     date_format(timestamp(`Duration 2`), 'HH:mm:ss') AS SA_Fixed_Duration,
   CASE
        WHEN date_format(SA_Normal_time, 'HH:mm:ss') BETWEEN '06:00:00' AND '07:59:00' THEN 'very early in the morning'
        WHEN date_format(SA_Normal_time, 'HH:mm:ss') BETWEEN '08:00:00' AND '09:59:00' THEN 'Early Morning'
        WHEN date_format(SA_Normal_time, 'HH:mm:ss') BETWEEN '10:00:00' AND '11:59:00' THEN 'Late morning'
        WHEN date_format(SA_Normal_time, 'HH:mm:ss') BETWEEN '12:00:00' AND '13:59:00' THEN 'Midday'
        WHEN date_format(SA_Normal_time, 'HH:mm:ss') BETWEEN '14:00:00' AND '15:59:00' THEN 'Afternoon'
        WHEN date_format(SA_Normal_time, 'HH:mm:ss') BETWEEN '16:00:00' AND '17:59:00' THEN 'Late Afternoon'
        WHEN date_format(SA_Normal_time, 'HH:mm:ss') BETWEEN '18:00:00' AND '19:59:00' THEN 'Evening'
ELSE 'NIght'
END AS Time_Bucket,

Dayname(RecordDate2) AS Day_name,
Monthname(RecordDate2) AS Month_name,
Dayofmonth(RecordDate2) As Day_of_Month
from `workspace`.`default`.`viewership_dataset` AS A
LEFT JOIN `workspace`.`default`.`user_profiles_dataset` AS B
ON A.UserID0 = B.UserID;

