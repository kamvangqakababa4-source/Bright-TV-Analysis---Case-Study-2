----------------------------------------------------------------------------------------------
---Checking Viwership By Channel
----------------------------------------------------------------------------------------------
select
      Channel2,
      COUNT(*) AS the_Most_Viewed_Show
from `workspace`.`default`.`viewership_dataset` AS A
LEFT JOIN `workspace`.`default`.`user_profiles_dataset` AS B
ON A.UserID0 = B.UserID
GROUP BY `Channel2`;

-----------------------------------------------------------------------------------------------
---Checking channel viewers that are 20 years and above In DESC order
----------------------------------------------------------------------------------------------
select 
       Channel2,
       Age
from `workspace`.`default`.`viewership_dataset` AS A
LEFT JOIN `workspace`.`default`.`user_profiles_dataset` AS B
ON A.UserID0 = B.UserID
WHERE Age >= 20
ORDER BY Age DESC;


