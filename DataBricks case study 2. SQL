-----------------------------------------------------------------------------------------------
---Checking Viewership by province
-----------------------------------------------------------------------------------------------

select
      Province,
      COUNT(*) AS Viewership_By_Province
from `workspace`.`default`.`viewership_dataset` AS A
LEFT JOIN `workspace`.`default`.`user_profiles_dataset` AS B
ON A.UserID0 = B.UserID
GROUP BY `Province`;

----------------------------------------------------------------------------------------------
---Checking Viwership By Race
----------------------------------------------------------------------------------------------

select
       Race,
       COUNT(*) AS viewership_By_Race
from `workspace`.`default`.`viewership_dataset` AS A
LEFT JOIN `workspace`.`default`.`user_profiles_dataset` AS B
ON A.UserID0 = B.UserID
GROUP BY `Race`;

-----------------------------------------------------------------------------------------------
---checking Viwership By Age
----------------------------------------------------------------------------------------------
select 
       Age,
       COUNT(*) AS Viewership_By_Age
from `workspace`.`default`.`viewership_dataset` AS A
LEFT JOIN `workspace`.`default`.`user_profiles_dataset` AS B
ON A.UserID0 = B.UserID
GROUP BY `Age`
ORDER BY Age ASC;

-----------------------------------------------------------------------------------------------
---Checking the Viewership By Gender
-----------------------------------------------------------------------------------------------

select
